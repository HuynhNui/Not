# Unity project source of truth:
# Keep Assets/, Packages/, ProjectSettings/ and all *.meta files in git.

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/
[Rr]ecordings/
.utmp/
Assets/_Recovery/
sysinfo.txt

# Addressables generated content
Assets/AddressableAssetsData/*/*.bin*

# IDE / editor files generated per developer
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.sln.iml

# OS files
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100/
.Trashes/
ehthumbs.db
Thumbs.db
Desktop.ini

# Build outputs and exported packages
*.apk
*.aab
*.app
*.exe
*.x86
*.x86_64
*.ipa
*.unitypackage

# Xcode / Apple generated project files
*.xcodeproj/
*.xcworkspace/
*.xcuserdata/
*.xcuserstate

# Gradle / Android Studio
.gradle/
build/

# Node / package managers, if tooling is added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local caches
[Ll]ibrary[Cc]ache/
.cache/

# Local environment files
.env
.env.*
!.env.example
