# Default text normalization
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf

# Unity YAML/text assets should stay diffable and mergeable.
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.controller text eol=lf
*.cs text eol=lf
*.fontsettings text eol=lf
*.guiskin text eol=lf
*.hlsl text eol=lf
*.inputactions text eol=lf
*.json text eol=lf
*.lighting text eol=lf
*.mask text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.prefab text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf
*.terrainlayer text eol=lf
*.txt text eol=lf
*.unity text eol=lf
*.uss text eol=lf
*.uxml text eol=lf
*.vfx text eol=lf

# Git LFS for binary/heavy assets.
