  lines:
  - speakerId: UNIT-07
    speakerName: UNIT-07
    text: "Three deployments. Same terrain. Same heat signatures shielding smaller lifeforms."
    avatar: {fileID: 0}
    blipAudio: {fileID: 0}
  - speakerId: UNIT-07
    speakerName: UNIT-07
    text: "Hostile behavior model inconsistent. They retreat toward nests, not command nodes."
    avatar: {fileID: 0}
    blipAudio: {fileID: 0}
  - speakerId: COMMAND
    speakerName: COMMAND
    text: "Ignore anomaly. Native resistance remains a relocation obstacle."
    avatar: {fileID: 0}
    blipAudio: {fileID: 0}
